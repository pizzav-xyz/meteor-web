{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./modules.schema.json",
  "title": "Meteor Web Modules Data",
  "description": "Specification for src/lib/modules.json.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/module"
  },
  "$defs": {
    "category": {
      "type": "string",
      "minLength": 1,
      "description": "Top-level module category shown in the UI. Supports built-in and addon-defined categories."
    },
    "settingType": {
      "type": "string",
      "enum": ["bool", "int", "double", "enum", "select", "keybind", "string", "color", "vector"],
      "description": "Setting control type used by the UI."
    },
    "setting": {
      "type": "object",
      "description": "A single module setting.",
      "additionalProperties": false,
      "required": ["name", "type", "group", "value"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the setting."
        },
        "type": {
          "$ref": "#/$defs/settingType"
        },
        "group": {
          "type": "string",
          "minLength": 1,
          "description": "Section/group label used in the module settings screen."
        },
        "value": {
          "description": "Current/default setting value.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "options": {
          "type": "array",
          "description": "Allowed values for enum settings.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "min": {
          "type": "number",
          "description": "Minimum numeric value for int/double settings."
        },
        "max": {
          "type": "number",
          "description": "Maximum numeric value for int/double settings."
        },
        "selectedCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of selected entries for select settings."
        },
        "totalCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total available entries for select settings."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "bool"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "boolean"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "int"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "integer"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "double"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "number"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "enum"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["options"],
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "select"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["selectedCount", "totalCount"],
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "keybind"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "string"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "color"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "vector"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "module": {
      "type": "object",
      "description": "A Meteor module entry.",
      "additionalProperties": false,
      "required": ["id", "name", "category", "description", "settings"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable slug identifier used by the UI and store."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name shown in the modules list."
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "description": {
          "type": "string",
          "description": "Module description shown in the detail panel."
        },
        "settings": {
          "type": "array",
          "description": "Settings available for the module, including bind settings.",
          "items": {
            "$ref": "#/$defs/setting"
          }
        }
      }
    }
  }
}
